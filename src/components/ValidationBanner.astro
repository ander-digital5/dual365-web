---
// src/components/ValidationBanner.astro
---

<div class="bg-[var(--verde)] py-12 relative overflow-hidden pink-strip-pattern">
    <div
        class="max-w-7xl mx-auto px-6 lg:px-12 flex flex-col md:flex-row items-center justify-between gap-10"
    >
        <div class="flex items-center gap-8">
            <div
                class="w-20 h-20 bg-white/10 rounded-[24px] flex items-center justify-center backdrop-blur-md border border-white/20 shadow-xl"
            >
                <span
                    class="material-symbols-outlined text-white text-4xl font-light"
                    >verified_user</span
                >
            </div>
            <div>
                <h3 class="serif text-3xl text-white">
                    Estándar de Excelencia en FP
                </h3>
                <p class="text-white/80 text-lg">
                    Validado por los centros de referencia nacional.
                </p>
            </div>
        </div>
        <div
            class="flex items-center gap-4 bg-white/10 px-8 py-4 rounded-2xl border border-white/20 backdrop-blur-xl"
        >
            <span class="material-symbols-outlined text-white"
                >workspace_premium</span
            >
            <span class="text-white font-black text-sm"
                >LA HERRAMIENTA QUE USA LA FP DEL PAIS VASCO</span
            >
        </div>
    </div>
</div>

<style>
    .pink-strip-pattern {
        background-image: radial-gradient(
            circle at 2px 2px,
            rgba(255, 255, 255, 0.15) 1px,
            transparent 0
        );
        background-size: 32px 32px;
    }
</style>
