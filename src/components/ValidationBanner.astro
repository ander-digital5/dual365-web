---
// src/components/ValidationBanner.astro
---

<div class="bg-[var(--verde)] py-24 relative overflow-hidden pink-strip-pattern">
    <div
        class="max-w-7xl mx-auto px-6 lg:px-12 flex flex-col md:flex-row items-center justify-between gap-32"
    >
        <div class="flex items-center gap-8">
            <div
                class="w-20 h-20 bg-white/10 rounded-[24px] flex items-center justify-center backdrop-blur-md border border-white/20 shadow-xl"
            >
                <span
                    class="material-symbols-outlined text-white text-4xl font-light"
                    >verified_user</span
                >
            </div>
            <div class="space-y-3">
                <h3 class="serif text-2xl text-white">
                    La educación más cerca de la empleabilidad real
                </h3>
                <p class="text-white/80 text-base">
                    dual365 conecta lo que las empresas necesitan con lo que los centros enseñan.
                </p>
            </div>
        </div>
        <div
            class="flex items-center gap-4 bg-white/10 px-8 py-4 rounded-2xl border border-white/20 backdrop-blur-xl"
        >
            <span class="material-symbols-outlined text-white"
                >workspace_premium</span
            >
            <span class="text-white font-black text-xs"
                >LA HERRAMIENTA QUE USA LA FP DEL PAIS VASCO</span
            >
        </div>
    </div>
</div>

<style>
    .pink-strip-pattern {
        background-image: radial-gradient(
            circle at 2px 2px,
            rgba(255, 255, 255, 0.15) 1px,
            transparent 0
        );
        background-size: 32px 32px;
    }
</style>
