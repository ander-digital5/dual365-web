---
// src/components/UserCard.astro
interface Props {
    icon: string;
    tag: string;
    title: string;
    description: string;
    toolName: string;
    colorClass: string; // e.g., "var(--rosa)" or "indigo-500"
    bgClass: string; // e.g., "var(--rosa-soft)" or "indigo-50"
}

const { icon, tag, title, description, toolName, colorClass, bgClass } =
    Astro.props;

// Determine if the color classes are custom CSS vars or Tailwind built-ins to format correctly
const isCustomColor = colorClass.startsWith("var");
const textClass = isCustomColor ? `text-[${colorClass}]` : `text-${colorClass}`;
const bgDivClass = isCustomColor ? `bg-[${bgClass}]` : `bg-${bgClass}`;
---

<div
    class="bg-white p-10 rounded-3xl border border-[var(--line)] hover:shadow-2xl transition-all group flex flex-col h-full"
>
    <div
        class={`w-16 h-16 ${bgDivClass} rounded-2xl flex items-center justify-center mb-8 group-hover:scale-110 transition-transform`}
    >
        <span class={`material-symbols-outlined ${textClass} text-3xl`}
            >{icon}
        </span>
    </div>
    <div class="mb-6">
        <span
            class={`text-[9px] font-extrabold ${textClass} ${bgDivClass} px-3 py-1.5 rounded-md uppercase tracking-widest`}
            >{tag}
        </span>
    </div>
    <h4 class="font-extrabold text-2xl mb-4">{title}</h4>
    <p class="text-gray-500 text-sm leading-relaxed mb-8 flex-grow">
        {description}
    </p>
    <div class="pt-6 border-t border-gray-50">
        <p class="text-xs font-bold text-[var(--ink)]">{toolName}</p>
    </div>
</div>
