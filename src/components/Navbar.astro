---
// src/components/Navbar.astro
---

<nav
    class="fixed top-0 left-0 right-0 z-[100] h-20 glass border-b border-[var(--line)] flex items-center px-6 lg:px-12 justify-between"
>
    <div class="flex items-center gap-2">
        <!-- El logo en base64 original ha sido truncado por su tamaño. Sustituir por la versión completa o un archivo estático en public/ -->
        <img alt="dual365" class="h-9" src="/logo.svg" />
    </div>
    <div class="hidden md:flex gap-10 items-center">
        <a
            class="text-sm font-semibold text-gray-500 hover:text-[var(--rosa)] transition-colors"
            href="#func">Funcionalidades</a
        >
        <a
            class="text-sm font-semibold text-gray-500 hover:text-[var(--rosa)] transition-colors"
            href="#usuarios">Usuarios</a
        >
        <a
            class="text-sm font-semibold text-gray-500 hover:text-[var(--rosa)] transition-colors"
            href="#dashboard">Dashboard</a
        >
        <a
            class="bg-[var(--ink)] text-white px-7 py-2.5 rounded-full text-sm font-bold hover:bg-opacity-90 transition-all shadow-lg shadow-black/5"
            href="#cta">Solicitar Demo</a
        >
    </div>
    <button class="md:hidden material-symbols-outlined p-2">menu</button>
</nav>
