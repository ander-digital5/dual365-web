---
// src/components/Dashboard.astro
---

<section class="pt-56 pb-48 px-6 lg:px-12 bg-white" id="dashboard">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-24 items-center">
        <div class="order-2 lg:order-1">
            <div
                class="bg-transparent p-1 rounded-[42px] shadow-[0_0_0_2px_var(--verde),0_0_40px_8px_rgba(61,170,78,0.25)]"
            >
                <div
                    class="bg-white p-14 rounded-[38px] relative overflow-hidden"
                >

                    <div
                        class="flex items-center justify-between border-b border-[var(--line)] pb-8 mb-10"
                    >
                        <div class="flex items-center gap-4">
                            <img
                                alt="logo"
                                class="h-4"
                                src="/logo.svg"
                            />
                            <span class="font-bold text-[var(--ink)] tracking-tight"
                                >Panel de Control</span
                            >
                        </div>
                        <div class="flex gap-2.5">
                            <div class="w-2.5 h-2.5 rounded-full bg-[var(--line)]">
                            </div>
                            <div
                                class="w-2.5 h-2.5 rounded-full bg-[var(--rosa)]"
                            >
                            </div>
                            <div class="w-2.5 h-2.5 rounded-full bg-[var(--line)]">
                            </div>
                        </div>
                    </div>
                    <div class="grid grid-cols-12 gap-8">
                        <div class="col-span-4 space-y-6">
                            <div
                                class="bg-[var(--verde-soft)]/40 p-6 rounded-2xl border border-[var(--line)]"
                            >
                                <p
                                    class="text-[10px] text-gray-600 uppercase font-black tracking-widest mb-6"
                                >
                                    Estado de Alumnos
                                </p>
                                <div class="space-y-4">
                                    <div class="flex items-center gap-3">
                                        <div
                                            class="w-2 h-2 rounded-full bg-[var(--verde)]"
                                        >
                                        </div>
                                        <span
                                            class="text-[11px] text-gray-700 font-medium"
                                            >Asignados (244)</span
                                        >
                                    </div>
                                    <div class="flex items-center gap-3">
                                        <div
                                            class="w-2 h-2 rounded-full bg-amber-400"
                                        >
                                        </div>
                                        <span
                                            class="text-[11px] text-gray-700 font-medium"
                                            >En espera (12)</span
                                        >
                                    </div>
                                    <div class="flex items-center gap-3">
                                        <div
                                            class="w-2 h-2 rounded-full bg-[var(--rosa)]"
                                        >
                                        </div>
                                        <span
                                            class="text-[11px] text-gray-700 font-medium"
                                            >Sin empresa (5)</span
                                        >
                                    </div>
                                </div>
                            </div>
                            <div
                                class="bg-gradient-to-br from-[var(--rosa)] to-[var(--rosa-mid)] p-6 rounded-2xl"
                            >
                                <p class="text-white font-bold text-xs mb-1">
                                    Nueva Alerta
                                </p>
                                <p class="text-white/80 text-[10px]">
                                    3 convenios pendientes de firma digital
                                    caducan hoy.
                                </p>
                            </div>
                        </div>
                        <div class="col-span-8 space-y-6">
                            <div
                                class="bg-[var(--verde-soft)]/40 p-8 rounded-2xl border border-[var(--line)]"
                            >
                                <p
                                    class="text-[10px] text-gray-600 uppercase font-black tracking-widest mb-8"
                                >
                                    FAMILIAS PROFESIONALES CON % DE PLAZAS
                                    CUBIERTAS
                                </p>
                                <div class="space-y-7">
                                    <div class="space-y-2">
                                        <div
                                            class="flex justify-between text-xs text-gray-700 font-bold"
                                        >
                                            <span>Informática</span>
                                            <span>92%</span>
                                        </div>
                                        <div
                                            class="h-1.5 w-full bg-gray-200 rounded-full overflow-hidden"
                                        >
                                            <div
                                                class="h-full bg-gradient-to-r from-[var(--rosa)] to-[var(--rosa-mid)] w-[92%]"
                                            >
                                            </div>
                                        </div>
                                    </div>
                                    <div class="space-y-2">
                                        <div
                                            class="flex justify-between text-xs text-gray-700 font-bold"
                                        >
                                            <span>Sanidad</span>
                                            <span>74%</span>
                                        </div>
                                        <div
                                            class="h-1.5 w-full bg-gray-200 rounded-full overflow-hidden"
                                        >
                                            <div
                                                class="h-full bg-gradient-to-r from-[var(--verde)] to-[var(--verde-mid)] w-[74%]"
                                            >
                                            </div>
                                        </div>
                                    </div>
                                    <div class="space-y-2">
                                        <div
                                            class="flex justify-between text-xs text-gray-700 font-bold"
                                        >
                                            <span>Administración</span>
                                            <span>88%</span>
                                        </div>
                                        <div
                                            class="h-1.5 w-full bg-gray-200 rounded-full overflow-hidden"
                                        >
                                            <div
                                                class="h-full bg-indigo-500 w-[88%]"
                                            >
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="order-1 lg:order-2 space-y-7">
            <span
                class="text-[var(--verde)] text-sm font-extrabold uppercase tracking-[0.3em]"
                >Educación Basada en Datos</span
            >
            <h2 class="serif text-6xl text-[var(--ink)] leading-tight">
                Datos que <em>mejoran</em> la educación.
            </h2>
            <p class="text-gray-700 text-xl leading-relaxed">
                Por primera vez, un centro de FP conoce exactamente qué competencias demanda su tejido empresarial y puede adaptarse de forma proactiva.
            </p>
            <div class="space-y-5">
                <div class="flex items-start gap-4">
                    <div
                        class="flex-shrink-0 mt-0.5"
                    >
                        <span class="material-symbols-outlined text-[var(--verde)] text-2xl" style="font-variation-settings: 'FILL' 1">check_circle</span>
                    </div>
                    <div>
                        <p class="font-bold text-[var(--ink)]">
                            Ofertas activas, asignaciones y convenios en un vistazo
                        </p>
                    </div>
                </div>
                <div class="flex items-start gap-4">
                    <div
                        class="flex-shrink-0 mt-0.5"
                    >
                        <span class="material-symbols-outlined text-[var(--verde)] text-2xl" style="font-variation-settings: 'FILL' 1">check_circle</span>
                    </div>
                    <div>
                        <p class="font-bold text-[var(--ink)]">
                            Mapa de competencias valoradas por empresas por ciclo formativo
                        </p>
                    </div>
                </div>
                <div class="flex items-start gap-4">
                    <div
                        class="flex-shrink-0 mt-0.5"
                    >
                        <span class="material-symbols-outlined text-[var(--verde)] text-2xl" style="font-variation-settings: 'FILL' 1">check_circle</span>
                    </div>
                    <div>
                        <p class="font-bold text-[var(--ink)]">
                            Tasa de inserción y satisfacción empresa / alumno
                        </p>
                    </div>
                </div>
                <div class="flex items-start gap-4">
                    <div
                        class="flex-shrink-0 mt-0.5"
                    >
                        <span class="material-symbols-outlined text-[var(--verde)] text-2xl" style="font-variation-settings: 'FILL' 1">check_circle</span>
                    </div>
                    <div>
                        <p class="font-bold text-[var(--ink)]">
                            Evolución del proceso DUAL a lo largo del curso
                        </p>
                    </div>
                </div>
                <div class="flex items-start gap-4">
                    <div
                        class="flex-shrink-0 mt-0.5"
                    >
                        <span class="material-symbols-outlined text-[var(--verde)] text-2xl" style="font-variation-settings: 'FILL' 1">check_circle</span>
                    </div>
                    <div>
                        <p class="font-bold text-[var(--ink)]">
                            Formación Continua de los trabajadores activos para capacitarse en las competencias actuales y futuras del sector
                        </p>
                    </div>
                </div>
                <div class="flex items-start gap-4">
                    <div
                        class="flex-shrink-0 mt-0.5"
                    >
                        <span class="material-symbols-outlined text-[var(--verde)] text-2xl" style="font-variation-settings: 'FILL' 1">check_circle</span>
                    </div>
                    <div>
                        <p class="font-bold text-[var(--ink)]">
                            Exportación de informes para inspección y administración educativa
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
