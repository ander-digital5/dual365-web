---
// src/components/ModalityCard.astro
interface Props {
    number: string;
    title: string;
    description: string;
    hoverColorVar: string; // e.g., "var(--rosa)" or "var(--verde)"
}

const { number, title, description, hoverColorVar } = Astro.props;

// Use dynamic Tailwind values appropriately for custom CSS variables
const borderHoverClass = hoverColorVar.startsWith("var")
    ? `hover:border-[${hoverColorVar}]`
    : `hover:border-${hoverColorVar}`;
---

<div
    class={`bg-white p-12 rounded-[32px] border border-[var(--line)] relative group overflow-hidden transition-all ${borderHoverClass}`}
>
    <span
        class="serif text-9xl absolute -bottom-6 -right-6 opacity-[0.03] group-hover:opacity-[0.06] transition-opacity select-none"
        >{number}
    </span>
    <h4 class="font-extrabold text-2xl mb-6 relative z-10">{title}</h4>
    <p class="text-gray-500 text-sm leading-relaxed relative z-10">
        {description}
    </p>
</div>
