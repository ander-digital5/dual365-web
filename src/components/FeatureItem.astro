---
// src/components/FeatureItem.astro
interface Props {
    number: string;
    title: string;
    description: string;
    colorVar: string; // e.g. "var(--rosa)"
}

const { number, title, description, colorVar } = Astro.props;
const textClass = `text-[${colorVar}]`;
---

<div class="flex gap-4">
    <div
        class={`w-12 h-12 rounded-full bg-white border border-[var(--line)] flex items-center justify-center font-bold text-sm z-10 shadow-sm ${textClass}`}
    >
        {number}
    </div>
    <div>
        <h4 class="font-bold text-xl mb-2">{title}</h4>
        <p class="text-gray-700 text-sm">{description}</p>
    </div>
</div>
