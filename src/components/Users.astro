---
// src/components/Users.astro
import UserCard from "./UserCard.astro";
---

<section class="py-32 px-6 lg:px-12 bg-[var(--rosa-pale)]" id="usuarios">
    <div class="max-w-7xl mx-auto">
        <div class="text-center max-w-2xl mx-auto mb-20">
            <span
                class="text-[var(--rosa)] text-xs font-extrabold uppercase tracking-[0.3em] mb-4 block"
                >Quién usa dual365</span
            >
            <h2 class="serif text-6xl text-[var(--ink)] mb-6">
                Una plataforma, <em>cuatro actores.</em>
            </h2>
            <p class="text-gray-500">
                Cada usuario accede a lo que necesita, cuando lo necesita, desde cualquier dispositivo.
            </p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
            <UserCard
                icon="account_balance"
                tag="Estratégico"
                title="Director/a del Centro"
                description="Dashboard completo con todos los indicadores DUAL. Visión estratégica de competencias demandadas por el tejido empresarial."
                toolName="VISIÓN GLOBAL"
                colorClass="var(--rosa)"
                bgClass="var(--rosa-soft)"
            />
            <UserCard
                icon="psychology"
                tag="Pedagógico"
                title="Profesor/a DUAL"
                description="Gestión completa: captación, asignación, seguimiento, evaluación y documentación. Todo centralizado."
                toolName="GESTIÓN TOTAL"
                colorClass="var(--verde)"
                bgClass="var(--verde-soft)"
            />
            <!-- Note: Tailwind utility classes don't need the custom format handling -->
            <UserCard
                icon="business_center"
                tag="Corporativo"
                title="Empresa"
                description="Portal propio con CVs seleccionados, alumnos asignados, calendarios y valoración de competencias."
                toolName="PORTAL EMPRESA"
                colorClass="indigo-500"
                bgClass="indigo-50"
            />
            <UserCard
                icon="person_pin"
                tag="Protagonista"
                title="Alumno/a"
                description="Toda la información de su proceso DUAL: empresa, tutor, calendario, convenio y evaluaciones."
                toolName="TRANSPARENCIA"
                colorClass="amber-500"
                bgClass="amber-50"
            />
        </div>
    </div>
</section>
