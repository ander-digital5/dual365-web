---
// src/components/Footer.astro
---

<footer class="py-16 px-6 lg:px-12 bg-white border-t border-[var(--line)]">
    <div class="max-w-7xl mx-auto">
        <div class="grid md:grid-cols-3 gap-12 mb-12">
            <div class="space-y-4">
                <img alt="dual365" class="h-8" src="/logo.svg" />
                <p class="text-sm text-gray-500">
                    Transformando la Formación Profesional Dual a través de tecnología.
                </p>
            </div>

            <div class="space-y-3">
                <h4 class="font-bold text-[var(--ink)] text-sm">Contacto</h4>
                <div class="space-y-2">
                    <a
                        href="mailto:info@digital5.es"
                        class="flex items-center gap-2 text-sm text-gray-500 hover:text-[var(--rosa)] transition-colors"
                    >
                        <span class="material-symbols-outlined text-base">mail</span>
                        info@digital5.es
                    </a>
                    <a
                        href="tel:+34944731824"
                        class="flex items-center gap-2 text-sm text-gray-500 hover:text-[var(--rosa)] transition-colors"
                    >
                        <span class="material-symbols-outlined text-base">phone</span>
                        944 73 18 24
                    </a>
                </div>
            </div>

            <div class="space-y-3">
                <h4 class="font-bold text-[var(--ink)] text-sm">Legal</h4>
                <div class="flex flex-col gap-2">
                    <a
                        href="/aviso-legal"
                        class="text-sm text-gray-500 hover:text-[var(--rosa)] transition-colors"
                    >
                        Aviso Legal
                    </a>
                    <a
                        href="/privacidad"
                        class="text-sm text-gray-500 hover:text-[var(--rosa)] transition-colors"
                    >
                        Política de Privacidad
                    </a>
                </div>
            </div>
        </div>

        <div class="border-t border-[var(--line)] pt-6 text-center">
            <p class="text-xs text-gray-400">© 2026 dual365. Todos los derechos reservados.</p>
        </div>
    </div>
</footer>
