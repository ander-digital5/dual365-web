---
// src/components/Footer.astro
---

<footer class="py-20 px-6 lg:px-12 bg-white border-t border-[var(--line)]">
    <div class="max-w-7xl mx-auto">
        <div class="grid md:grid-cols-4 gap-16 mb-20">
            <div class="md:col-span-1 space-y-6">
                <img alt="dual365" class="h-8" src="/logo.svg" />
                <p class="text-sm text-gray-500">
                    Transformando la Formación Profesional Dual en todo el país
                    a través de tecnología.
                </p>
            </div>
            <div class="md:col-span-1 space-y-4">
                <h4 class="font-bold text-[var(--ink)]">Producto</h4>
                <ul class="text-sm text-gray-500 space-y-2">
                    <li>
                        <a
                            href="#func"
                            class="hover:text-[var(--rosa)] transition-colors"
                            >Funcionalidades</a>
                    </li>
                    <li>
                        <a
                            href="#usuarios"
                            class="hover:text-[var(--rosa)] transition-colors"
                            >Ecosistema</a>
                    </li>
                    <li>
                        <a
                            href="#dashboard"
                            class="hover:text-[var(--rosa)] transition-colors"
                            >Dashboard</a>
                    </li>
                    <li>
                        <a
                            href="#modalidades"
                            class="hover:text-[var(--rosa)] transition-colors"
                            >Modalidades</a>
                    </li>
                </ul>
            </div>
            <div class="md:col-span-1 space-y-4">
                <h4 class="font-bold text-[var(--ink)]">Soporte</h4>
                <ul class="text-sm text-gray-500 space-y-2">
                    <li>
                        <a
                            href="#"
                            class="hover:text-[var(--rosa)] transition-colors"
                            >Centro de Ayuda</a>
                    </li>
                    <li>
                        <a
                            href="#"
                            class="hover:text-[var(--rosa)] transition-colors"
                            >Contacto</a>
                    </li>
                    <li>
                        <a
                            href="#"
                            class="hover:text-[var(--rosa)] transition-colors"
                            >Normativa Legal</a>
                    </li>
                </ul>
            </div>
        </div>
        <div
            class="border-t border-[var(--line)] pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-gray-400"
        >
            <p>© 2026 dual365. Todos los derechos reservados.</p>
            <div class="flex gap-4">
                <a href="#" class="hover:text-[var(--ink)] transition-colors"
                    >Aviso Legal</a
                >
                <a href="#" class="hover:text-[var(--ink)] transition-colors"
                    >Privacidad</a
                >
            </div>
        </div>
    </div>
</footer>
