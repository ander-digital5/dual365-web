---
// src/components/Features.astro
import FeatureItem from "./FeatureItem.astro";
import FeatureCard from "./FeatureCard.astro";
---

<section class="py-48 px-6 lg:px-12 bg-white" id="func">
    <div class="max-w-7xl mx-auto">
        <div class="max-w-3xl mb-24">
            <span
                class="text-[var(--rosa)] text-xs font-extrabold uppercase tracking-[0.3em] mb-4 block"
                >Funcionalidades clave</span
            >
            <h2
                class="serif text-6xl lg:text-7xl text-[var(--ink)] leading-tight mb-8"
            >
                Todo el ciclo DUAL, <br /><em>de principio a fin.</em>
            </h2>
            <p class="text-gray-700 text-xl">
                dual365 cubre cada etapa sin herramientas adicionales. Un único entorno para todo el proceso.
            </p>
        </div>
        <div class="grid lg:grid-cols-12 gap-6">
            <div class="lg:col-span-4 space-y-16 relative">
                <div
                    class="absolute left-[23px] top-4 bottom-4 w-[1px] bg-gradient-to-b from-[var(--rosa)] via-[var(--rosa-mid)] to-[var(--verde)]"
                >
                </div>
                <FeatureItem
                    number="01"
                    title="Captación de empresas · Mail Marketing + CRM"
                    description="Gestión del contacto comercial, registro de llamadas y seguimiento del estado de las ofertas DUAL."
                    colorVar="var(--rosa)"
                />
                <FeatureItem
                    number="02"
                    title="Selección y asignación de alumnos"
                    description="Matching automático entre CVs y perfiles de oferta. Envío a empresa y asignación definitiva en un clic."
                    colorVar="var(--rosa-mid)"
                />
                <FeatureItem
                    number="03"
                    title="Convenio y documentación"
                    description="Generación automática del convenio y documentación oficial, proceso de firma y custodia segura en la plataforma."
                    colorVar="var(--verde-mid)"
                />
                <FeatureItem
                    number="04"
                    title="Calendarios y seguimiento"
                    description="Calendarios de trabajo generados automáticamente. Seguimiento en tiempo real del proceso formativo."
                    colorVar="var(--verde)"
                />
                <FeatureItem
                    number="05"
                    title="Evaluación y competencias"
                    description="El docente evalúa el proceso. La empresa valora competencias. El centro obtiene datos curriculares accionables."
                    colorVar="var(--verde)"
                />
                <FeatureItem
                    number="06"
                    title="Dashboard con datos actualizados"
                    description="Panel de control en tiempo real con todos los indicadores clave para el seguimiento y toma de decisiones del equipo directivo."
                    colorVar="var(--verde)"
                />
            </div>
            <div class="lg:col-span-8 grid md:grid-cols-2 lg:grid-cols-2 gap-8">
                <FeatureCard
                    icon="domain"
                    title="Portal de la Empresa"
                    description="Acceso propio con ofertas activas, alumnos asignados y herramienta de valoración de competencias."
                    iconColorClass="text-[var(--rosa)]"
                />
                <FeatureCard
                    icon="school"
                    title="Portal del Alumno"
                    description="Acceso a empresa asignada, calendario, convenio y evaluaciones desde cualquier dispositivo."
                    iconColorClass="text-[var(--rosa-mid)]"
                />
                <FeatureCard
                    icon="analytics"
                    title="Dashboard Directivo"
                    description="Panel con todos los KPIs del DUAL actualizados en tiempo real para la toma de decisiones."
                    iconColorClass="text-[var(--verde-mid)]"
                />
                <FeatureCard
                    icon="history_edu"
                    title="Inteligencia Curricular"
                    description="Las competencias valoradas por las empresas retroalimentan el diseño curricular del centro."
                    iconColorClass="text-[var(--verde)]"
                />
                <FeatureCard
                    icon="hub"
                    title="Firma y Custodia"
                    description="Toda la documentación oficial firmada, custodiada y accesible."
                    iconColorClass="text-indigo-500"
                />
                <FeatureCard
                    icon="support_agent"
                    title="Bolsa de Trabajo DUAL"
                    description="Portal desde donde impulsar la empleabilidad y la creación de talento."
                    iconColorClass="text-amber-500"
                />
            </div>
        </div>
    </div>
</section>
