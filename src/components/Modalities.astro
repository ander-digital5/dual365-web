---
// src/components/Modalities.astro
import ModalityCard from "./ModalityCard.astro";
---

<section class="py-48 px-6 lg:px-12 bg-[var(--verde-soft)]/20" id="modalidades">
    <div class="max-w-7xl mx-auto">
        <div class="text-center max-w-3xl mx-auto mb-24">
            <span
                class="text-[var(--rosa)] text-xs font-extrabold uppercase tracking-[0.3em] mb-4 block"
                >Máxima compatibilidad</span
            >
            <h2 class="serif text-6xl text-[var(--ink)] mb-8">
                Todas las <em>modalidades DUAL</em> de la nueva Ley de FP
            </h2>
            <p class="text-gray-700 text-lg">
                dual365 cubre cualquier combinación de empresa y centro, cumpliendo la normativa vigente en todas las comunidades autónomas.
            </p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            <ModalityCard
                number="01"
                title="DUAL General"
                description="Formación compartida entre centro educativo y empresa con convenio de colaboración. El modelo más extendido en España."
                hoverColorVar="var(--rosa)"
            />
            <ModalityCard
                number="02"
                title="DUAL Intensivo"
                description="Mayor carga de formación en empresa, con un mínimo del 35% del tiempo en el puesto de trabajo real."
                hoverColorVar="var(--rosa)"
            />
            <ModalityCard
                number="03"
                title="DUAL en Contrato de Formación"
                description="El alumno tiene contrato laboral con la empresa durante su formación DUAL, con sus implicaciones económicas y legales."
                hoverColorVar="var(--rosa)"
            />
            <ModalityCard
                number="04"
                title="DUAL Compartido"
                description="Varios centros y/o empresas comparten la formación y el seguimiento del proceso DUAL del alumno."
                hoverColorVar="var(--verde)"
            />
            <ModalityCard
                number="05"
                title="FCT Estándar"
                description="La clásica Formación en Centros de Trabajo también se gestiona con dual365 para centralizar toda la gestión de prácticas."
                hoverColorVar="var(--verde)"
            />
            <ModalityCard
                number="06"
                title="Otras modalidades autonómicas"
                description="Adaptaciones específicas de cada comunidad autónoma. dual365 es configurable para cualquier normativa regional."
                hoverColorVar="var(--verde)"
            />
        </div>
    </div>
</section>
